# Normalise line endings so the repo is consistent across Windows/macOS/Linux.
# Without this, git warns "LF will be replaced by CRLF" on every checkout on Windows.
* text=auto eol=lf

# The Gradle wrapper script must stay LF or it won't run on Unix.
gradlew text eol=lf
*.bat   text eol=crlf

# Binary assets — never touch their bytes.
*.jar binary
*.png binary
*.gif binary
*.jpg binary
